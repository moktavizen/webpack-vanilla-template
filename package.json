{
  "name": "webpack-vanilla-template",
  "version": "1.0.0",
  "description": "Vanilla HTML/CSS/JS starter template for Webpack",
  "keywords": [],
  "homepage": "https://github.com/moktavizen/restaurant#readme",
  "bugs": {
    "url": "https://github.com/moktavizen/restaurant/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moktavizen/restaurant.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --open --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "merge": "git checkout gh-pages && git merge main --no-edit",
    "deploy": "git add dist -f && git commit -m 'Deployment commit' && git subtree push --prefix dist origin gh-pages && git checkout main"
  },
  "devDependencies": {
    "css-loader": "^7.1.3",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
}
